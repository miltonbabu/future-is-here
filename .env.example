# Zhipu GLM API key — used for article + achievement generation (server-side)
# Also used for client-side image generation (exposed to browser via NEXT_PUBLIC_*)
# Get yours at: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
NEXT_PUBLIC_GLM_API_KEY=your_glm_api_key_here

# OpenAI API key (optional, rarely used — times out from China)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Upstash Redis — for persistent share storage in production
# Auto-configured when you add Upstash Redis via Vercel dashboard
# Get yours at: https://console.upstash.com/ (or Vercel Marketplace → Storage → Redis)
# Without these, the app falls back to file-based JSON (local dev only)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
